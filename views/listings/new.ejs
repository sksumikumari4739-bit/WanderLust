<% layout("/layouts/boilerplate") -%>

<div class="row mt-3"> 
    <div class="col-md-8 offset-2">
        <!-- <br><br> -->
    <h3>Create New Listing</h3>
    <form
     method="POST" 
     action="/listings" 
     novalidate class="needs-validation" 
     encType="multipart/form-data"
     >
        <div class="mb-3">
            <label for="title" class="form-label"> Title</label>
            <input 
             name="listing[title]" 
             placeholder="Add a catchy Title" 
             type="text"
             class="form-control" required
            />
            <div class="valid-feedback">
                </div>
        </div>
        
        <div class="mb-3">
            <label for="description" class="form-label"> Description</label>
            <textarea
              name="listing[description]" 
              class="form-control" 
              required
            ></textarea>
            <div class="invalid-feedback">
                Please provide a description for your listing.
            </div>
        </div>
         
          <div class="mb-3">
          <label for="image" class="form-label">Upload Listing Image</label>
          <input
             name="listing[image]"  
             type="file" 
             class="form-control"
            />
            required
        </div>


            <div class="invalid-feedback">
                    Please provide an image URL for your listing.
            </div>
            
         
        
    
        <div class="row">
            <div class="mb-3 col-md-4">
             <label for="price" class="form-label"> Price</label>
                <input 
                 name="listing[price]" 
                 placeholder="1200" 
                 
                 class="form-control" required
                 />

                 <div class="invalid-feedback">
                    Please provide a price for your listing.

                 </div>
            </div>
         

            <div  class="mb-3 col-md-8">
            
             <label for="country" class="form-label"> Country</label>
             <input 
                 name="listing[country]" 
                 placeholder="India" 
                 type="text"
                 class="form-control" required
              />

              <div class="invalid-feedback">
                    Please provide a country for your listing.
                </div>
            </div> 
        </div>


        <div class="mb-3">
         <label for="location" class="form-label"> Location</label>
         <input 
             name="listing[location]" 
             placeholder="Jaipur, Rajasthan" 
             type="text"
             class="form-control" required
            />

            <div class="invalid-feedback">
                    Please provide a location for your listing.
                </div>  
        </div>

        <button class="btn btn-dark add-btn mt-3">Add</button>
    </form>
   
    </div>  
</div>

